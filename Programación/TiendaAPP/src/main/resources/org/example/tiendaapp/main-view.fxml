<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.tiendaapp.MainController">
   <top>
      <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Primera App JAVA FX" BorderPane.alignment="CENTER">
         <font>
            <Font name="Calibri Light" size="24.0" />
         </font>
      </Text>
   </top>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <center>
      <VBox alignment="CENTER" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <TextField fx:id="editNombre" alignment="CENTER" promptText="Introduce tu nombre">
               <cursor>
                  <Cursor fx:constant="DEFAULT" />
               </cursor>
            </TextField>
            <Button fx:id="botonSaludar" mnemonicParsing="false" text="Saludar">
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
            </Button>
         </children>
      </VBox>
   </center>
   <bottom>
      <Text fx:id="textoSaludo" strokeType="OUTSIDE" strokeWidth="0.0" BorderPane.alignment="CENTER" />
   </bottom>
</BorderPane>
